NEWSAPI_KEY=your_newsapi_key
BING_ENDPOINT=https://api.bing.microsoft.com/v7.0/news/search
BING_KEY=your_bing_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=HealtherBot/1.0
TWITTER_BEARER_TOKEN=your_x_bearer_token
GOOGLE_API_KEY=your_google_api_key
# Healther Backend Configuration
# Copy this file to .env and fill in your own values

# OpenAI API Key (required for Healther AI assistant)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Backend port (default: 3000)
PORT=3000

# JWT Secret (generate a random string for production)
JWT_SECRET=your-random-jwt-secret-key-here-min-32-chars

# Node environment
NODE_ENV=development
